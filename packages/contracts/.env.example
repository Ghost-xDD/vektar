# Environment Variables for Contract Deployment
# Copy to .env and fill in your values, then: source .env

# ============================================================================
# REQUIRED for deployment
# ============================================================================

# Your deployer private key (DO NOT COMMIT)
export PRIVATE_KEY=0x...

# Base Sepolia RPC URL (get from Alchemy/Infura)
export BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Polygon Amoy RPC URL (get from Alchemy/Infura)
export POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY

# ============================================================================
# OPTIONAL for contract verification
# ============================================================================

# Get from https://basescan.org/myapikey
export BASESCAN_API_KEY=

# Get from https://polygonscan.com/myapikey
export POLYGONSCAN_API_KEY=

# ============================================================================
# OPTIONAL deployment settings
# ============================================================================

# Max LTV increase per update (basis points)
# - Demo: 10000 (100%, instant updates)
# - Production: 200 (2%, gradual updates)
export MAX_LTV_INCREASE_PER_UPDATE=10000

# CRE Forwarder address (leave empty to use deployer as placeholder)
export CRE_FORWARDER_ADDRESS=

# ============================================================================
# Usage
# ============================================================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Fill in your values in .env
#
# 3. Load variables:
#    source .env
#
# 4. Deploy:
#    ./deploy-demo.sh
#
